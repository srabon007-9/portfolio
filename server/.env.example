# MongoDB Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# It will look like: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_connection_string_here

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# Email notifications for new contact form messages
# Example SMTP values for Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=your.email@gmail.com
# CONTACT_NOTIFY_EMAIL=srabonahmed2002@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_NOTIFY_EMAIL=srabonahmed2002@gmail.com

# Private admin inbox key for message management endpoints
ADMIN_INBOX_KEY=choose_a_long_random_secret
